{
  "name": "gta-rp",
  "version": "0.0.0",
  "private": true,
  "description": "AI-powered South African GTA RP server — monorepo root",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky",
    "fivem:dev": "docker compose -f apps/fivem-resources/docker-compose.yml up",
    "fivem:deps": "node apps/fivem-resources/scripts/fetch-deps.mjs",
    "fivem:update": "git submodule update --init --recursive apps/fivem-resources/ox_lib apps/fivem-resources/ox_inventory apps/fivem-resources/qbx_core"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
