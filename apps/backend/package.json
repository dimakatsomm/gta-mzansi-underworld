{
  "name": "@gtarp/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@gtarp/db": "workspace:*",
    "@gtarp/event-bus": "workspace:*",
    "@gtarp/event-schema": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "ioredis": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.5"
  }
}
