# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=gtarp
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gtarp
DATABASE_URL=postgresql://gtarp:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/gtarp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── NATS ──────────────────────────────────────────────────────────────────────
# NATS_AUTH_TOKEN is embedded in nats.production.conf via env-var expansion.
# All services must use nats://<token>@127.0.0.1:4222 in NATS_URL.
NATS_AUTH_TOKEN=CHANGE_ME_RANDOM_32_CHAR_SECRET
NATS_URL=nats://CHANGE_ME_RANDOM_32_CHAR_SECRET@127.0.0.1:4222
NATS_STREAM=gtarp

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...

# ── AI Cost Budgeting ─────────────────────────────────────────────────────────
AI_TOKEN_BUDGET_PER_PLAYER_HOUR=20000
AI_TOKEN_BUDGET_PER_SERVER_HOUR=2000000
AI_CACHE_TARGET_HIT_RATE=0.7

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_INCIDENT_CHANNEL_ID=
DISCORD_DISPATCH_CHANNEL_ID=
DISCORD_MOD_LOG_CHANNEL_ID=
DISCORD_MOD_ROLE_IDS=

# ── Service Ports ─────────────────────────────────────────────────────────────
BACKEND_PORT=3001
AI_ORCHESTRATOR_PORT=3002
EVENT_WORKER_PORT=3003

# ── FiveM ─────────────────────────────────────────────────────────────────────
FIVEM_INGEST_TOKEN=CHANGE_ME_RANDOM_32_CHAR_SECRET
SV_LICENCEKEY=CHANGE_ME_FIVEM_LICENCE_KEY
