{
  "uid": "ai-cost-001",
  "title": "AI Cost Dashboard",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "AI Calls (24h rolling) by Tier",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "ai_calls_24h",
          "legendFormat": "tier={{tier}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Rolling 24h Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "ai_cost_usd_24h",
          "legendFormat": "24h cost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      }
    }
  ],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "Africa/Johannesburg",
  "tags": ["ai", "cost", "gtarp"]
}
