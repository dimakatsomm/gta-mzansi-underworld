# --- Postgres ---
DATABASE_URL=postgresql://gtarp:gtarp@localhost:5432/gtarp

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- NATS ---
NATS_URL=nats://localhost:4222
NATS_STREAM=gtarp

# --- AI providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# --- AI cost guard ---
AI_TOKEN_BUDGET_PER_PLAYER_HOUR=20000
AI_TOKEN_BUDGET_PER_SERVER_HOUR=2000000
AI_CACHE_TARGET_HIT_RATE=0.7

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_INCIDENT_CHANNEL_ID=

# --- Backend ---
BACKEND_PORT=3001
AI_ORCHESTRATOR_PORT=3002
EVENT_WORKER_PORT=3003

# --- FiveM ingest auth (shared secret between FiveM resource and backend) ---
FIVEM_INGEST_TOKEN=change-me-in-production

# --- Stripe (M9) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
