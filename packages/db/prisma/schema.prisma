// Prisma schema for GTA RP. Source of truth for persistent state.
// EventLog row content (id, type, payload, occurredAt, actor, correlationId)
// is append-only — do not mutate the recorded event. The `published` flag is
// the single exception: it is a publish-receipt bit flipped false→true exactly
// once after the ingest path emits to JetStream, and is used to retry publish
// on the next ingest attempt for the same event id.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ Identity ============

model Player {
  id              String   @id @default(uuid())
  discordId       String?  @unique
  fivemLicense    String   @unique
  displayName     String
  createdAt       DateTime @default(now())
  lastSeenAt      DateTime @default(now())

  identities      Identity[]
  familyMembers   FamilyMember[]
  gangMemberships GangMembership[]
  crimesAsPerp    CrimePerpetrator[]
  arrests         Arrest[]   @relation("Suspect")
  arrestsByOfficer Arrest[]  @relation("Officer")
  reputation      Reputation[]
  warrants        Warrant[]
  criminalRecord  CriminalRecord?
  ownedBusinesses Business[] @relation("BusinessOwner")
  ownedProperties Property[] @relation("PropertyOwner")
  ownedVehicles   Vehicle[]  @relation("VehicleOwner")
  bribesPaid      Bribe[]    @relation("Payer")
  bribesReceived  Bribe[]    @relation("Receiver")
}

model Identity {
  id         String   @id @default(uuid())
  playerId   String
  firstName  String
  lastName   String
  idNumber   String   @unique
  birthDate  DateTime
  province   String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

// ============ Family / Legacy ============

model Family {
  id         String   @id @default(uuid())
  surname    String
  foundedAt  DateTime @default(now())
  motto      String?
  reputation Float    @default(0)

  members     FamilyMember[]
  households  Household[]
  businesses  Business[]
  reputations Reputation[]
}

model FamilyMember {
  id        String   @id @default(uuid())
  familyId  String
  playerId  String
  role      String   // patriarch, matriarch, sibling, child, in_law
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([familyId, playerId])
  @@index([playerId])
}

model Household {
  id         String   @id @default(uuid())
  familyId   String?
  propertyId String   @unique
  formedAt   DateTime @default(now())

  family     Family?  @relation(fields: [familyId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
}

model Relationship {
  id        String   @id @default(uuid())
  aPlayerId String
  bPlayerId String
  type      String   // dating, married, divorced, estranged, parent_of
  startedAt DateTime @default(now())
  endedAt   DateTime?

  @@unique([aPlayerId, bPlayerId, type])
  @@index([aPlayerId])
  @@index([bPlayerId])
}

// ============ Property / Vehicle / Business ============

model Property {
  id          String     @id @default(uuid())
  ownerId     String?
  address     String
  province    String
  area        String
  marketValue Decimal    @db.Decimal(12, 2)
  acquiredAt  DateTime?

  owner       Player?    @relation("PropertyOwner", fields: [ownerId], references: [id])
  household   Household?
}

model Vehicle {
  id        String   @id @default(uuid())
  ownerId   String?
  plate     String   @unique
  make      String
  model     String
  color     String
  stolen    Boolean  @default(false)

  owner     Player?  @relation("VehicleOwner", fields: [ownerId], references: [id])
}

model Business {
  id          String   @id @default(uuid())
  ownerId     String?
  familyId    String?
  name        String
  kind        String   // shisa_nyama, tavern, taxi_assoc, security, dealership, logistics, construction, club, tech, mining
  province    String
  area        String
  isFront     Boolean  @default(false)
  laundering  Boolean  @default(false)
  reputation  Float    @default(0)

  owner       Player?  @relation("BusinessOwner", fields: [ownerId], references: [id])
  family      Family?  @relation(fields: [familyId], references: [id])
}

// ============ Crime / Evidence / Police ============

model Crime {
  id          String   @id @default(uuid())
  type        String   // CrimeType enum on TS side
  severity    String   // CrimeSeverity
  committedAt DateTime @default(now())
  province    String
  area        String
  x           Float
  y           Float
  z           Float
  resolved    Boolean  @default(false)
  notes       String?

  perpetrators CrimePerpetrator[]
  evidence     Evidence[]
  warrants     Warrant[]
  witnesses    WitnessReport[]
}

model CrimePerpetrator {
  crimeId   String
  playerId  String
  role      String   // primary, accomplice, getaway

  crime     Crime    @relation(fields: [crimeId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([crimeId, playerId])
}

model Evidence {
  id         String   @id @default(uuid())
  crimeId    String
  kind       String   // dna, fingerprint, fiber, casing, cctv, statement
  collectedAt DateTime @default(now())
  custodyId  String?  // officer player id
  contamination Float @default(0)
  storedAt   String?

  crime      Crime    @relation(fields: [crimeId], references: [id], onDelete: Cascade)
}

model WitnessReport {
  id         String   @id @default(uuid())
  crimeId    String
  witnessRef String   // npc id or player id
  quality    Float
  statement  String   @db.Text
  recordedAt DateTime @default(now())
  contradicted Boolean @default(false)

  crime      Crime    @relation(fields: [crimeId], references: [id], onDelete: Cascade)
  @@index([crimeId])
}

model Warrant {
  id        String   @id @default(uuid())
  crimeId   String
  subjectId String
  issuedAt  DateTime @default(now())
  status    String   @default("open") // open, served, quashed

  crime     Crime    @relation(fields: [crimeId], references: [id])
  subject   Player   @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  @@index([subjectId])
  @@index([crimeId])
}

model Arrest {
  id         String   @id @default(uuid())
  suspectId  String
  officerId  String
  charges    String[] // CrimeType[]
  madeAt     DateTime @default(now())
  province   String
  area       String
  released   Boolean  @default(false)

  suspect    Player   @relation("Suspect", fields: [suspectId], references: [id])
  officer    Player   @relation("Officer", fields: [officerId], references: [id])
}

model CriminalRecord {
  id        String   @id @default(uuid())
  playerId  String   @unique
  totalArrests   Int @default(0)
  totalConvictions Int @default(0)
  notorietyScore Float @default(0)
  updatedAt DateTime @updatedAt

  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Bribe {
  id         String   @id @default(uuid())
  payerId    String
  receiverId String
  amount     Decimal  @db.Decimal(12, 2)
  purpose    String
  paidAt     DateTime @default(now())

  payer      Player   @relation("Payer", fields: [payerId], references: [id])
  receiver   Player   @relation("Receiver", fields: [receiverId], references: [id])
}

// ============ Gangs / Territory ============

model Gang {
  id         String   @id @default(uuid())
  name       String   @unique
  founded    DateTime @default(now())
  colors     String?
  reputation Float    @default(0)

  members     GangMembership[]
  territories Territory[]    @relation("ControllingGang")
  alliancesA  Alliance[]      @relation("GangA")
  alliancesB  Alliance[]      @relation("GangB")
  reputations Reputation[]
}

model GangMembership {
  id       String   @id @default(uuid())
  gangId   String
  playerId String
  rank     String   // recruit, soldier, lieutenant, captain, boss
  joinedAt DateTime @default(now())
  leftAt   DateTime?

  gang     Gang     @relation(fields: [gangId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gangId, playerId])
}

model Territory {
  id            String   @id @default(uuid())
  name          String
  province      String
  area          String
  controllerId  String?
  control       Float    @default(0) // 0..1

  controller    Gang?    @relation("ControllingGang", fields: [controllerId], references: [id])
}

model Alliance {
  id       String   @id @default(uuid())
  gangAId  String
  gangBId  String
  type     String   // alliance, ceasefire, vendetta
  since    DateTime @default(now())

  gangA    Gang     @relation("GangA", fields: [gangAId], references: [id])
  gangB    Gang     @relation("GangB", fields: [gangBId], references: [id])
  @@unique([gangAId, gangBId, type])
}

// ============ Media / Reputation ============

model NewsEvent {
  id         String   @id @default(uuid())
  headline   String
  body       String   @db.Text
  category   String   // crime, politics, business, gossip
  publishedAt DateTime @default(now())
  province   String?
  area       String?
  sourceEventIds String[]
}

model RadioBroadcast {
  id         String   @id @default(uuid())
  station    String
  script     String   @db.Text
  audioUrl   String?
  airedAt    DateTime @default(now())
}

model Rumor {
  id        String   @id @default(uuid())
  text      String   @db.Text
  truthScore Float   // 0..1
  spreadAt  DateTime @default(now())
}

model Reputation {
  id        String   @id @default(uuid())
  playerId  String?
  familyId  String?
  gangId    String?
  area      String?
  score     Float    @default(0)
  updatedAt DateTime @updatedAt

  player    Player?  @relation(fields: [playerId], references: [id])
  family    Family?  @relation(fields: [familyId], references: [id], onDelete: SetNull)
  gang      Gang?    @relation(fields: [gangId], references: [id], onDelete: SetNull)
  @@index([playerId])
  @@index([familyId])
  @@index([gangId])
  @@index([area])
}

// ============ Event sourcing / AI usage ============

model EventLog {
  id            String   @id @default(uuid())
  type          String
  version       Int
  occurredAt    DateTime
  receivedAt    DateTime @default(now())
  actor         String?
  correlationId String?
  payload       Json
  published     Boolean  @default(false)

  @@index([type])
  @@index([occurredAt])
  @@index([correlationId])
}

model AiUsage {
  id         String   @id @default(uuid())
  provider   String   // openai, anthropic, elevenlabs
  model      String
  tier       Int
  purpose    String   // dispatch, witness, news, story, podcast, voice
  promptTokens Int
  completionTokens Int
  audioSeconds Float?
  costUsd    Decimal  @db.Decimal(10, 6)
  cacheHit   Boolean  @default(false)
  cacheKey   String?
  occurredAt DateTime @default(now())

  @@index([provider, model])
  @@index([occurredAt])
  @@index([purpose])
}
