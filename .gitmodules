# Submodule URLs for ox_lib, ox_inventory, and qbx_core.
#
# WARNING: no commit SHAs are recorded in the superproject, so
# `git submodule update --init` will check out the default-branch HEAD,
# NOT the pinned versions (v3.14.0 / v2.35.1 / v1.37.0).
#
# Use `pnpm fivem:deps` (apps/fivem-resources/scripts/fetch-deps.mjs)
# as the authoritative reproducible install path — it shallow-clones at
# the exact pinned tags.

[submodule "apps/fivem-resources/ox_lib"]
	path = apps/fivem-resources/ox_lib
	url = https://github.com/overextended/ox_lib
	branch = v3.14.0

[submodule "apps/fivem-resources/ox_inventory"]
	path = apps/fivem-resources/ox_inventory
	url = https://github.com/overextended/ox_inventory
	branch = v2.35.1

[submodule "apps/fivem-resources/qbx_core"]
	path = apps/fivem-resources/qbx_core
	url = https://github.com/Qbox-project/qbx_core
	branch = v1.37.0
